{
  "name": "@univer/configurator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run generate:styles",
    "prebuild": "npm run generate:styles",
    "pretest": "npm run generate:styles",
    "build": "vue-tsc -b && vite build",
    "generate:styles": "npx tsx scripts/generate-iframe-styles.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:scripts": "npm test"
  },
  "dependencies": {
    "configurator-web": "file:..",
    "three": "^0.170.0",
    "vue": "^3.5.24"
  },
  "exports": {
    ".": "./dist/configurator.js"
  },
  "main": "./dist/configurator.js",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.10.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  }
}
